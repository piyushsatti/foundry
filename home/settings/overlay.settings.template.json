  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/settings-lock.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/secret-scanner.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sensitive-file-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/claude-files-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ai-artifact-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/persistence-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/claude-self-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/audit-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/settings-lock.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/secret-scanner.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cwd-drift-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/unsandboxed-install-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pipe-rce-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/docker-escape-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/bash-cred-read-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/persistence-bash-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/claude-files-bash-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/xattr-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/audit-log.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/main-branch-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/conventional-commit.sh"
          },
          {
            "type": "command",
            "command": "INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty'); if echo \"$CMD\" | grep -qi 'psql' && echo \"$CMD\" | grep -qiE 'DROP[[:space:]]+(TABLE|DATABASE|SCHEMA|INDEX)|TRUNCATE[[:space:]]'; then jq -n '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Destructive DDL (DROP/TRUNCATE) detected in psql command. Run manually if intentional.\"}}'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [[ \"$f\" == *.py ]] && uvx ruff format \"$f\" 2>/dev/null; } || true",
            "statusMessage": "Formatting Python..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; if [[ \"$f\" == *.py ]]; then result=$(uvx ruff check \"$f\" 2>/dev/null); code=$?; if [ $code -ne 0 ] && [ -n \"$result\" ]; then jq -n --arg ctx \"Ruff issues in $f:\\n$result\" '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":$ctx}}'; fi; fi; } || true",
            "statusMessage": "Linting Python..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/docker-compose-validator.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/xattr-tagger.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/audit-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/audit-log.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/install-tagger.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-log.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Summarize the 3-5 most important decisions, context, or progress from this session that should survive context compaction. Be concise — bullet points only.",
            "statusMessage": "Saving session context before compaction..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -n '{\"systemMessage\":\"Reminder: Never add Co-Authored-By trailers to commits.\"}'",
            "statusMessage": "Restoring key rules..."
          },
          {
            "type": "command",
            "command": "jq -n '{\"systemMessage\":\"If this session is working in a named scope, consider running /primer to update the scope primer with key decisions from this session.\"}'",
            "statusMessage": "Scope primer check..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pending-cleanup-check.sh",
            "statusMessage": "Checking for pending cleanup items..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/project-bootstrap-check.sh",
            "statusMessage": "Checking project workflow setup..."
          },
          {
            "type": "command",
            "command": "jq -n '{\"additionalContext\":\"Reminder: Name this session with /name <description> so you can find it later.\"}'",
            "statusMessage": "Session naming reminder"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scope-context.sh",
            "statusMessage": "Loading scope context..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/memory-durability.sh --mode=sessionstart",
            "statusMessage": "Re-anchoring durable memory..."
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "enableWorkflows": false,
  "workflowKeywordTriggerEnabled": false,
  "statusLine": {
    "type": "command",
